# Database
POSTGRES_USER=kpss_user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=kpss_db
DATABASE_URL=postgresql://kpss_user:CHANGE_ME_SECURE_PASSWORD@kpss-postgres:5432/kpss_db

# Redis
REDIS_URL=redis://kpss-redis:6379

# Ports (auto-assigned by deploy_safe.sh)
KPSS_PG_PORT=30001
KPSS_REDIS_PORT=30002
KPSS_API_PORT=30003
KPSS_ADMIN_PORT=30004

# LLM Configuration (server-side only - NEVER expose to frontend)
LLM_API_KEY=CHANGE_ME_LLM_API_KEY
LLM_API_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4
LLM_VERIFIER_MODEL=gpt-4
LLM_DRY_RUN=true

# AI Job Configuration
AUTO_PUBLISH_RATE=0.05
AI_JOB_MAX_RETRIES=3

# Sentry (observability)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# JWT
JWT_SECRET=CHANGE_ME_JWT_SECRET
JWT_EXPIRY=7d

# App
NODE_ENV=production
API_BASE_URL=http://localhost:30003
