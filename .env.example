# =============================================================================
# Salen Hocam - Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in your actual values
# WARNING: Never commit .env to version control!

# -----------------------------------------------------------------------------
# Backend Configuration (REQUIRED)
# -----------------------------------------------------------------------------

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/salen_hocam

# JWT Secret (CRITICAL - Must be changed in production!)
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-very-long-random-secret-in-production

# Server Port
PORT=3000

# Node Environment (development, production, test)
NODE_ENV=development

# -----------------------------------------------------------------------------
# Mobile App Configuration (REQUIRED)
# -----------------------------------------------------------------------------

# API Base URL
# Development: use localhost or your local IP (e.g., http://192.168.1.100:3000)
# Production: use your deployed backend URL (e.g., https://api.salenhocam.com)
EXPO_PUBLIC_API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Optional: AI Integration (Future Feature)
# -----------------------------------------------------------------------------

# LLM settings for AI-generated questions
LLM_DRY_RUN=true
LLM_API_KEY=sk-placeholder

# OpenAI API Key
# OPENAI_API_KEY=sk-your-api-key-here

# -----------------------------------------------------------------------------
# Optional: Monitoring & Error Tracking
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Optional: Database Configuration (for Docker)
# -----------------------------------------------------------------------------

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=salen_hocam
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Security Notes
# -----------------------------------------------------------------------------
# 
# 1. JWT_SECRET must be at least 32 characters in production
# 2. Use strong passwords for database
# 3. Rotate secrets periodically
# 4. Use environment-specific files (.env.production, .env.staging)
