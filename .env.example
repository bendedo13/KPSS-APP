# Copy this file to .env and fill in your values.
# NEVER commit the real .env to source control.

# PostgreSQL connection string
DATABASE_URL=postgresql://kpss_user:change_me@localhost:5432/kpss

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=change_me_before_production

# Backend port
PORT=3000

# LLM settings
LLM_DRY_RUN=true
LLM_API_KEY=sk-placeholder

# Sentry DSN (optional)
SENTRY_DSN=

# Mobile app — set before building the Expo app
EXPO_PUBLIC_API_URL=http://localhost:3000
