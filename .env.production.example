# =============================================================================
# Salen Hocam - Production Environment Variables
# =============================================================================
# Copy this file to .env in production and fill with actual values
# CRITICAL: Keep this file secure and never commit to version control!

# -----------------------------------------------------------------------------
# Production Backend Configuration
# -----------------------------------------------------------------------------

# PostgreSQL Database
DATABASE_URL=postgresql://salen_user:CHANGE_THIS_PASSWORD@postgres:5432/salen_hocam
POSTGRES_USER=salen_user
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=salen_hocam
POSTGRES_PORT=5433

# JWT Secret (MUST be changed!)
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_SECRET_AT_LEAST_64_CHARACTERS_LONG

# Server Configuration
PORT=3000
BACKEND_PORT=3001
NODE_ENV=production

# CORS Configuration
# Add your frontend domains (comma-separated)
CORS_ORIGIN=https://salenhocam.com,https://app.salenhocam.com,https://api.salenhocam.com

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=60000
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_TIME_WINDOW=60000

# -----------------------------------------------------------------------------
# Optional: Monitoring & Logging
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking
SENTRY_DSN=

# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Optional: AI Features (Future)
# -----------------------------------------------------------------------------

LLM_DRY_RUN=true
LLM_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# DEPLOYMENT CHECKLIST
# -----------------------------------------------------------------------------
# 
# [ ] Changed JWT_SECRET to a strong random string (64+ chars)
# [ ] Set strong POSTGRES_PASSWORD
# [ ] Updated CORS_ORIGIN with your actual domains
# [ ] Configured DATABASE_URL with correct credentials
# [ ] Set POSTGRES_PORT to avoid conflicts (default: 5433)
# [ ] Set BACKEND_PORT to avoid conflicts (default: 3001)
# [ ] Reviewed and adjusted rate limits if needed
# [ ] Set up SSL/TLS certificates (nginx/traefik)
# [ ] Configured firewall rules
# [ ] Set up automated backups for PostgreSQL
# [ ] Configured monitoring/alerting (optional)
