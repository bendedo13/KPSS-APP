{
  "name": "kpss-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev:backend": "npm --workspace=services/backend run dev",
    "dev:worker": "npm --workspace=services/worker run dev",
    "build": "npm --workspaces run build",
    "lint": "npm --workspaces run lint",
    "test": "npm --workspaces run test"
  }
}
