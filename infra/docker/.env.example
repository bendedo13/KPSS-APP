# KPSS Platform Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to version control

# Compose project name (auto-generated by deploy_safe.sh, do not set manually)
# COMPOSE_PROJECT_NAME=kpss_xxxxxx

# Database
POSTGRES_DB=kpss
POSTGRES_USER=kpss
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Service Ports (auto-detected by deploy_safe.sh)
POSTGRES_PORT=30001
REDIS_PORT=30002
BACKEND_PORT=30003
ADMIN_PORT=30004

# JWT
JWT_SECRET=CHANGE_ME_STRONG_SECRET_32_CHARS_MIN

# LLM Integration
# Store API keys server-side only, NEVER in frontend code
LLM_API_KEY=YOUR_LLM_API_KEY_HERE
LLM_DRY_RUN=true
AUTO_PUBLISH_RATE=0.05

# Next.js Admin
NEXT_PUBLIC_API_URL=http://localhost:30003

# Sentry (optional)
SENTRY_DSN=

# Node environment
NODE_ENV=production
