# KPSS Platform — .env.example
# Copy to .env and fill in values. NEVER commit .env to git.

COMPOSE_PROJECT_NAME=kpss_CHANGE_ME
NODE_ENV=production

# CORS — comma-separated list of allowed origins (leave empty to block all cross-origin)
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Database
POSTGRES_DB=kpss
POSTGRES_USER=kpss
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Ports (will be auto-assigned by deploy_safe.sh if not set)
POSTGRES_HOST_PORT=
REDIS_HOST_PORT=
BACKEND_HOST_PORT=
ADMIN_HOST_PORT=

# Auth
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET
NEXTAUTH_URL=https://admin.example.com

# LLM (server-side only — NEVER expose to frontend)
LLM_DRY_RUN=true
OPENAI_API_KEY=sk-CHANGE_ME
# Alternative: use HashiCorp Vault or AWS Secrets Manager (see README)

# Admin API URL (used by Next.js admin panel at build time)
NEXT_PUBLIC_API_URL=https://api.example.com

# Observability
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME

# Canary / AI publish rate (0.0 - 1.0). Default 5%
AUTO_PUBLISH_RATE=0.05
